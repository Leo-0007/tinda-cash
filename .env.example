# DATABASE (Neon.tech - free tier)
DATABASE_URL="postgresql://user:password@host/tindacash?sslmode=require"

# JWT AUTH
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# FX RATES (ExchangeRate-API - free tier: 1500 req/month)
EXCHANGE_RATE_API_KEY="your_key_from_exchangerate-api.com"

# KYC - Onfido (https://onfido.com)
ONFIDO_API_TOKEN="your_onfido_api_token"
ONFIDO_WEBHOOK_TOKEN="your_onfido_webhook_token"

# PAYMENTS AFRICA - Flutterwave (https://flutterwave.com)
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-xxxxx"
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-xxxxx"
FLUTTERWAVE_ENCRYPTION_KEY="xxxxx"

# MOBILE MONEY - pawaPay (https://pawapay.io)
PAWAPAY_API_TOKEN="your_pawapay_api_token"
PAWAPAY_BASE_URL="https://api.sandbox.pawapay.io"

# RECEPTION EU - Wise Platform (https://wise.com/gb/platform)
WISE_API_KEY="your_wise_api_key"
WISE_PROFILE_ID="your_profile_id"
WISE_BASE_URL="https://api.sandbox.transferwise.tech"

# WALLET MULTI-DEVISE - Airwallex (https://airwallex.com)
AIRWALLEX_CLIENT_ID="your_client_id"
AIRWALLEX_API_KEY="your_api_key"
AIRWALLEX_BASE_URL="https://api-demo.airwallex.com"

# SMS - Twilio (https://twilio.com)
TWILIO_ACCOUNT_SID="ACxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# EMAIL - SendGrid (https://sendgrid.com)
SENDGRID_API_KEY="SG.xxxxx"
FROM_EMAIL="noreply@tindacash.com"

# APP
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Tinda Cash"
NODE_ENV="development"
